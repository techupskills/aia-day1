{
   // "build": { "dockerfile": "Dockerfile" },
    "image": "mcr.microsoft.com/devcontainers/base:bookworm",
    "remoteEnv": {
        "OLLAMA_MODEL": "llama3.2:3b"
    },
    "hostRequirements": {
       "cpus": 8,
       "memory": "16gb",
       "storage": "64gb"
    },
    "features": {
       "ghcr.io/devcontainers/features/docker-from-docker:1": {},
       "ghcr.io/devcontainers/features/github-cli:1": {},
       "ghcr.io/devcontainers/features/python:1": {},
       "node": {
               "version": "lts",
               "nodeGypDependencies": true
        }
    },
    "customizations": {
        "vscode": {
            "settings": {
                "python.terminal.activateEnvInCurrentTerminal": true,
                "python.defaultInterpreterPath": "${containerWorkspaceFolder}/py_env/bin/python",
                "github.copilot.enable": {
                  "*": false,
                  "plaintext": false,
                  "markdown": false,
                  "scminput": false
                 },
                 "github.copilot.enableAutoComplete": false,
                 "editor.inlineSuggest.enabled": false,
                 "github.copilot.inlineSuggest.enable": false,
                 "github.copilot.chat.enable": false,
                 "github.copilotChat.showInExplorer": false,
                 "workbench.startupEditor": "readme",
                 // Open Markdown files in preview mode by default
                 "workbench.editorAssociations": {
                     "*.md": "vscode.markdown.preview.editor"
                 },
                 // Ensure terminals source .bashrc (including ollama aliases)
                 "terminal.integrated.defaultProfile.linux": "bash",
                 "terminal.integrated.profiles.linux": {
                     "bash": {
                         "path": "bash",
                         "args": ["-l"]
                     }
                 }
            },
            "extensions": [
               "mathematic.vscode-pdf",
               "vstirbu.vscode-mermaid-preview"
            ]
        }
    },
    "onCreateCommand": "bash -i scripts/pysetup.sh py_env",
    "updateContentCommand": "bash -i scripts/pysetup.sh py_env", 
    "postCreateCommand": "bash -i scripts/startOllama.sh && py_env/bin/python scripts/warmup.py",
    "postAttachCommand": "bash scripts/post_attach_ollama.sh"
}
